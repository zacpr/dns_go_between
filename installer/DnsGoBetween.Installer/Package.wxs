<?xml version="1.0" encoding="UTF-8"?>
<!--
  Package.wxs  WiX v4 top-level package definition.
  Directories, feature tree, and UI dialog set are defined here.
  The Windows Service component lives in Service.wxs.
  All other published files are pulled in via HarvestDirectory (see .wixproj).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="DNS Go-Between"
    Manufacturer="DNS Go-Between"
    Version="$(var.MsiVersion)"
    UpgradeCode="7B3F1A2E-9C4D-4F8B-A1E3-2D7C8B9F0E1A"
    Scope="perMachine">

    <SummaryInformation
      Keywords="Installer"
      Description="DNS Go-Between  REST API and web UI for Windows DNS Server management" />

    <!--
      MajorUpgrade: any previous version is removed before the new one is installed.
      Prevents duplicate installs and gives a clean upgrade path.
    -->
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed. Uninstall it first." />

    <!-- Embed all cab files into the MSI so it ships as a single file. -->
    <MediaTemplate EmbedCab="yes" />

    <!--
      Configuration Properties.
      Each non-secret dialog field has a <RegistrySearch> child so that on an
      upgrade, the previous install's values are pre-loaded by AppSearch
      before the ConfigDlg renders. The registry values are written by the
      InstallerStateRegistry component (see fragment below) at the end of
      each install. MajorUpgrade.Schedule="afterInstallInitialize" runs
      AppSearch BEFORE the old product is removed, so the values survive
      the upgrade swap.
      Secrets (CERT_PFX_PASSWORD, SERVICE_PASSWORD) are intentionally NOT
      persisted - update-config.ps1 preserves the existing appsettings.json
      PfxPassword when the dialog field is left blank.
    -->
    <Property Id="ALLOWEDZONES" Value="example.com" Secure="yes">
      <RegistrySearch Id="SearchAllowedZones"  Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="AllowedZones"   Type="raw" Bitness="always64" />
    </Property>
    <Property Id="PORT" Value="6790" Secure="yes">
      <RegistrySearch Id="SearchPort"          Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="Port"           Type="raw" Bitness="always64" />
    </Property>
    <Property Id="API_HOSTNAME" Secure="yes">
      <RegistrySearch Id="SearchApiHostname"   Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="ApiHostname"    Type="raw" Bitness="always64" />
    </Property>
    <Property Id="CERT_SOURCE" Value="STORE" Secure="yes">
      <RegistrySearch Id="SearchCertSource"    Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="CertSource"     Type="raw" Bitness="always64" />
    </Property>
    <Property Id="CERT_THUMBPRINT" Secure="yes">
      <RegistrySearch Id="SearchCertThumbprint" Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="CertThumbprint" Type="raw" Bitness="always64" />
    </Property>
    <Property Id="CERT_PFX_PATH" Secure="yes">
      <RegistrySearch Id="SearchCertPfxPath"   Root="HKLM" Key="Software\DnsGoBetween\Installer" Name="CertPfxPath"    Type="raw" Bitness="always64" />
    </Property>
    <Property Id="CERT_PFX_PASSWORD" Hidden="yes" Secure="yes" />
    <Property Id="SERVICE_ACCOUNT" Value="LocalSystem" Secure="yes" />
    <Property Id="SERVICE_PASSWORD" Hidden="yes" Secure="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!--
      Dialog-flow overrides: place the custom ConfigDlg before InstallDirDlg.
      This avoids conflicting with the built-in InstallDir Next handler from
      WixUI_InstallDir, which otherwise skips the custom dialog.
      Kept here rather than inside <ui:WixUI> to avoid a WiX 4.0.5 bug
      (WIX0200) where Publish children of a ui: element are rejected due to a
      namespace mismatch.
    -->
    <UI>
      <DialogRef Id="ConfigDlg" />
      <Publish Dialog="WelcomeDlg"     Control="Next" Event="NewDialog" Value="ConfigDlg"      Order="2" />
      <Publish Dialog="ConfigDlg"      Control="Back" Event="NewDialog" Value="WelcomeDlg"     Order="1" />
      <Publish Dialog="ConfigDlg"      Control="Next" Event="NewDialog" Value="InstallDirDlg"  Order="1" />
      <Publish Dialog="InstallDirDlg"  Control="Back" Event="NewDialog" Value="ConfigDlg"      Order="2" />
    </UI>

    <Feature Id="Main" Title="DNS Go-Between" Level="1">
      <ComponentGroupRef Id="ServiceComponent" />
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentGroupRef Id="InstallerStateComponents" />
    </Feature>

    <CustomAction
      Id="DeleteFirewallApi"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall delete rule name="DNS Go-Between API"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="AddFirewallApi"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall add rule name="DNS Go-Between API" dir=in action=allow protocol=TCP localport=[PORT] profile=domain,private remoteip=any'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="DeleteFirewallApiOnUninstall"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall delete rule name="DNS Go-Between API"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="UpdateConfig"
      Directory="System64Folder"
      ExeCommand='powershell.exe -nol -nop -noni -ep Bypass -F "[INSTALLFOLDER]scripts\update-config.ps1" "[INSTALLFOLDER]\|[ALLOWEDZONES]|[PORT]|[API_HOSTNAME]|[CERT_SOURCE]|[CERT_THUMBPRINT]|[CERT_PFX_PATH]|[CERT_PFX_PASSWORD]"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="DeleteFirewallApi" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="AddFirewallApi" After="DeleteFirewallApi" Condition="NOT REMOVE" />
      <Custom Action="UpdateConfig" After="AddFirewallApi" Condition="NOT REMOVE" />
      <Custom Action="DeleteFirewallApiOnUninstall" Before="RemoveFiles" Condition='REMOVE="ALL"' />
    </InstallExecuteSequence>

  </Package>

  <!-- Directory layout -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DnsGoBetween" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DNS Go-Between" />
    </StandardDirectory>
  </Fragment>

  <!--
    Installer state persistence.
    Writes the non-secret config-dialog values to HKLM so that the next
    install (upgrade) can pre-populate the dialog via <RegistrySearch>.
    Secrets are deliberately omitted from this registry surface.
  -->
  <Fragment>
    <ComponentGroup Id="InstallerStateComponents" Directory="INSTALLFOLDER">
      <Component Id="InstallerStateRegistry" Guid="B8F2D4E1-9C3A-4F5B-A6D7-2E8C1F3B9D4A">
        <RegistryKey Root="HKLM" Key="Software\DnsGoBetween\Installer" ForceCreateOnInstall="yes" ForceDeleteOnUninstall="yes">
          <RegistryValue Name="AllowedZones"    Type="string" Value="[ALLOWEDZONES]"     KeyPath="yes" />
          <RegistryValue Name="Port"            Type="string" Value="[PORT]" />
          <RegistryValue Name="ApiHostname"     Type="string" Value="[API_HOSTNAME]" />
          <RegistryValue Name="CertSource"      Type="string" Value="[CERT_SOURCE]" />
          <RegistryValue Name="CertThumbprint"  Type="string" Value="[CERT_THUMBPRINT]" />
          <RegistryValue Name="CertPfxPath"     Type="string" Value="[CERT_PFX_PATH]" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
