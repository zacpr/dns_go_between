<?xml version="1.0" encoding="UTF-8"?>
<!--
  Package.wxs  WiX v4 top-level package definition.
  Directories, feature tree, and UI dialog set are defined here.
  The Windows Service component lives in Service.wxs.
  All other published files are pulled in via HarvestDirectory (see .wixproj).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="DNS Go-Between"
    Manufacturer="DNS Go-Between"
    Version="1.0.0"
    UpgradeCode="7B3F1A2E-9C4D-4F8B-A1E3-2D7C8B9F0E1A"
    Scope="perMachine">

    <SummaryInformation
      Keywords="Installer"
      Description="DNS Go-Between  REST API and web UI for Windows DNS Server management" />

    <!--
      MajorUpgrade: any previous version is removed before the new one is installed.
      Prevents duplicate installs and gives a clean upgrade path.
    -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed. Uninstall it first." />

    <!-- Embed all cab files into the MSI so it ships as a single file. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Configuration Properties -->
    <Property Id="ALLOWEDZONES" Value="example.com" Secure="yes" />
    <Property Id="PORT" Value="6790" Secure="yes" />
    <Property Id="SERVICE_ACCOUNT" Value="LocalSystem" Secure="yes" />
    <Property Id="SERVICE_PASSWORD" Hidden="yes" Secure="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!--
      Dialog-flow overrides: insert the custom ConfigDlg between
      InstallDirDlg and VerifyReadyDlg.  Kept here rather than inside
      <ui:WixUI> to avoid a WiX 4.0.5 bug (WIX0200) where Publish
      children of a ui: element are rejected due to a namespace mismatch.
    -->
    <UI>
      <Publish Dialog="WelcomeDlg"     Control="Next" Event="NewDialog" Value="InstallDirDlg"  Order="2" />
      <Publish Dialog="InstallDirDlg"  Control="Back" Event="NewDialog" Value="WelcomeDlg"     Order="2" />
      <Publish Dialog="InstallDirDlg"  Control="Next" Event="NewDialog" Value="ConfigDlg"      Order="3" />
      <Publish Dialog="ConfigDlg"      Control="Back" Event="NewDialog" Value="InstallDirDlg"  Order="1" />
      <Publish Dialog="ConfigDlg"      Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="ConfigDlg"      Order="2" />
    </UI>

    <Feature Id="Main" Title="DNS Go-Between" Level="1">
      <ComponentGroupRef Id="ServiceComponent" />
      <ComponentGroupRef Id="HarvestedFiles" />
    </Feature>

    <CustomAction
      Id="DeleteFirewallApi"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall delete rule name="DNS Go-Between API"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="AddFirewallApi"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall add rule name="DNS Go-Between API" dir=in action=allow protocol=TCP localport=[PORT] profile=domain,private remoteip=localsubnet'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="DeleteFirewallApiOnUninstall"
      Directory="SystemFolder"
      ExeCommand='netsh advfirewall firewall delete rule name="DNS Go-Between API"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="UpdateConfig"
      Directory="System64Folder"
      ExeCommand='WindowsPowerShell\v1.0\powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "[INSTALLFOLDER]scripts\update-config.ps1" -InstallDir "[INSTALLFOLDER]\" -AllowedZonesString "[ALLOWEDZONES]" -HttpsPort "[PORT]"'
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="DeleteFirewallApi" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="AddFirewallApi" After="DeleteFirewallApi" Condition="NOT REMOVE" />
      <Custom Action="UpdateConfig" After="AddFirewallApi" Condition="NOT REMOVE" />
      <Custom Action="DeleteFirewallApiOnUninstall" Before="RemoveFiles" Condition='REMOVE="ALL"' />
    </InstallExecuteSequence>

  </Package>

  <!-- Directory layout -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DnsGoBetween" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DNS Go-Between" />
    </StandardDirectory>
  </Fragment>

</Wix>
