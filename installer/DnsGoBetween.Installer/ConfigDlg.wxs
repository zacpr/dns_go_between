<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>
      <Dialog Id="ConfigDlg" Width="370" Height="410" Title="[ProductName] Configuration">
        <Control Id="Next" Type="PushButton" X="236" Y="383" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Back" Type="PushButton" X="180" Y="383" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="383" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>

        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Configure the local Windows DNS provider and HTTPS port. Cloud providers are configured in the web UI after install." />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="220" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}DNS Configuration" />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="374" Width="370" Height="0" />

        <Control Id="AllowedZonesLabel" Type="Text" X="20" Y="60" Width="320" Height="15" NoPrefix="yes" Text="Local Windows zone filter (comma-separated, optional — blank = all zones):" />
        <Control Id="AllowedZonesEdit" Type="Edit" X="20" Y="75" Width="320" Height="18" Property="ALLOWEDZONES" />

        <Control Id="PortLabel" Type="Text" X="20" Y="104" Width="200" Height="15" NoPrefix="yes" Text="HTTPS Port:" />
        <Control Id="PortEdit" Type="Edit" X="20" Y="119" Width="90" Height="18" Property="PORT" />

        <Control Id="ApiHostnameLabel" Type="Text" X="20" Y="140" Width="320" Height="15" NoPrefix="yes" Text="Custom API hostname (optional, e.g. dnsapi.example.com):" />
        <Control Id="ApiHostnameEdit" Type="Edit" X="20" Y="155" Width="320" Height="18" Property="API_HOSTNAME" />

        <Control Id="WarningText" Type="Text" X="20" Y="178" Width="320" Height="15" NoPrefix="yes" Text="Port must be 1-65535." />

        <Control Id="CertSourceLabel" Type="Text" X="20" Y="195" Width="320" Height="15" NoPrefix="yes" Text="TLS certificate source (recommended: STORE):" />
        <Control Id="CertSourceRadio" Type="RadioButtonGroup" X="20" Y="210" Width="320" Height="34" Property="CERT_SOURCE">
          <RadioButtonGroup Property="CERT_SOURCE">
            <RadioButton Value="STORE" X="0" Y="0" Width="320" Height="16" Text="Use existing LocalMachine\\My certificate (thumbprint optional)" />
            <RadioButton Value="PFX" X="0" Y="16" Width="300" Height="16" Text="Use a PFX file path and password" />
          </RadioButtonGroup>
        </Control>

        <Control Id="ThumbprintLabel" Type="Text" X="20" Y="250" Width="320" Height="15" NoPrefix="yes" Text="Certificate thumbprint (optional in STORE mode):" />
        <Control Id="ThumbprintEdit" Type="Edit" X="20" Y="265" Width="320" Height="18" Property="CERT_THUMBPRINT" />

        <Control Id="PfxPathLabel" Type="Text" X="20" Y="288" Width="320" Height="15" NoPrefix="yes" Text="PFX file path (required in PFX mode):" />
        <Control Id="PfxPathEdit" Type="Edit" X="20" Y="303" Width="320" Height="18" Property="CERT_PFX_PATH" />

        <Control Id="PfxPasswordLabel" Type="Text" X="20" Y="324" Width="320" Height="15" NoPrefix="yes" Text="PFX password (for PFX mode):" />
        <Control Id="PfxPasswordEdit" Type="Edit" X="20" Y="339" Width="320" Height="18" Property="CERT_PFX_PASSWORD" Password="yes" />
        <Control Id="PfxPasswordHint" Type="Text" X="20" Y="358" Width="320" Height="12" NoPrefix="yes" Transparent="yes" Text="On upgrade, leave blank to keep the current PFX password." />
      </Dialog>
    </UI>
  </Fragment>
</Wix>
