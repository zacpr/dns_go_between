<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>
      <Dialog Id="ConfigDlg" Width="370" Height="270" Title="[ProductName] Configuration">
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>

        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="Please specify the initial DNS zones allowed for management." />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}DNS Configuration" />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="AllowedZonesLabel" Type="Text" X="20" Y="60" Width="290" Height="15" NoPrefix="yes" Text="Allowed DNS Zones (comma-separated):" />
        <Control Id="AllowedZonesEdit" Type="Edit" X="20" Y="75" Width="320" Height="18" Property="ALLOWEDZONES" />
        
        <Control Id="WarningText" Type="Text" X="20" Y="100" Width="320" Height="30" Text="Note: You can change these later in the appsettings.json file in the installation folder." />
      </Dialog>
    </UI>
  </Fragment>
</Wix>