<?xml version="1.0" encoding="UTF-8"?>
<!--
  Service.wxs — Windows Service installation component.

  The service EXE is the KeyPath for this component so Windows Installer tracks it.
  ServiceInstall creates the service; ServiceControl starts it on install and
  stops + removes it on uninstall.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>

    <!-- ── Windows Service ──────────────────────────────────────────────── -->
    <ComponentGroup Id="ServiceComponent" Directory="INSTALLFOLDER">
      <Component Id="ServiceExeComp" Guid="A2B3C4D5-E6F7-4890-B1C2-D3E4F5A6B7C8">
        <!--
          Source is resolved via the BindPath set in .wixproj.
          No absolute path needed here — WiX finds it in the publish output.
        -->
        <File Id="MainExe"
              Source="DnsGoBetween.Api.exe"
              KeyPath="yes" />

        <ServiceInstall
          Id="SvcInstall"
          Name="DnsGoBetween"
          DisplayName="DNS Go-Between"
          Description="REST API and web UI for Windows DNS Server record management"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="LocalSystem" />

        <!--
          Stop="both"      — stop the service on both uninstall and upgrades.
          Remove="uninstall" — delete the service entry on uninstall.
        -->
        <ServiceControl
          Id="SvcControl"
          Name="DnsGoBetween"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>

      <!-- Start Menu shortcut to reopen MSI maintenance mode -->
      <Component Id="ModifyShortcutComp" Directory="ApplicationProgramsFolder" Guid="C8A52BC2-9F31-46F8-BDCA-5ED1F9F10A61">
        <Shortcut
          Id="ModifyDnsGoBetween"
          Name="Modify DNS Go-Between"
          Description="Change allowed zones and HTTP port"
          Target="[SystemFolder]msiexec.exe"
          Arguments="/i [ProductCode]"
          WorkingDirectory="INSTALLFOLDER" />

        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />

        <RegistryValue
          Root="HKLM"
          Key="Software\DNS Go-Between"
          Name="StartMenuShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

  </Fragment>

</Wix>
