@using DnsGoBetween.Core.Interfaces
@using DnsGoBetween.Core.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@page "/"
@page "/dns"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDnsRecordService DnsService
@inject ILogger<DnsTree> Logger
@inject IJSRuntime JS

<PageTitle>DNS Manager</PageTitle>
<h1>DNS Record Manager</h1>

@if (_loading)
{
    <p class="loading">&#x23F3; Loading zones&hellip;</p>
}
else if (_error is not null)
{
    <div class="alert-danger">@_error <button @onclick="() => _error = null">&#x2715;</button></div>
}

@if (!_loading)
{
    <div class="search-bar">
        <input @ref="_searchInput" 
               @bind="_searchQuery"
               @oninput="@((ChangeEventArgs e) => { _searchQuery = e.Value?.ToString() ?? string.Empty; UpdateSearchResults(); })"
               @onkeydown="HandleSearchKeydown"
               type="text"
               placeholder="🔍 Search zones, hosts, records (Ctrl+F)…"
               class="search-input" />
        @if (!string.IsNullOrEmpty(_searchQuery))
        {
            <button @onclick="ClearSearchAsync" class="btn-clear-search" title="Clear search">✕</button>
        }
        @if (_searchResults > 0)
        {
            <span class="search-results">@_searchResults match@(_searchResults == 1 ? "" : "es")</span>
        }
    </div>

    <div class="dns-tree">
        @foreach (var zone in _zones)
        {
            var zoneMatches = MatchesSearch(zone.Name);
            var hasMatchingRecords = false;
            
            if (_zoneRecords.TryGetValue(zone.Name, out var records))
            {
                hasMatchingRecords = records.Any(r => MatchesSearch(r.HostName) || MatchesSearch(r.Data));
            }
            
            if (!zoneMatches && !hasMatchingRecords && !string.IsNullOrEmpty(_searchQuery))
                continue;

            <div class="zone-node @(zoneMatches ? "search-highlight" : "")">
                <span class="zone-toggle" @onclick="() => ToggleZoneAsync(zone.Name, hasMatchingRecords)">
                    @(_expandedZones.Contains(zone.Name) ? "▼" : "▶")
                    <strong>@zone.Name</strong>
                    <span class="badge">@(zone.ZoneType ?? "Zone")</span>
                </span>

                @if (_expandedZones.Contains(zone.Name))
                {
                    @if (_zoneLoading.Contains(zone.Name))
                    {
                        <p class="indent loading">&#x23F3; Loading records&hellip;</p>
                    }
                    else if (_zoneRecords.TryGetValue(zone.Name, out var zoneRecords))
                    {
                        @foreach (var hostGroup in zoneRecords.GroupBy(r => r.HostName).OrderBy(g => g.Key))
                        {
                            var hostKey = $"{zone.Name}|{hostGroup.Key}";
                            var hostMatches = MatchesSearch(hostGroup.Key);
                            var matchingRecords = hostGroup.Where(r => MatchesSearch(r.Data) || string.IsNullOrEmpty(_searchQuery)).ToList();
                            
                            if (!hostMatches && matchingRecords.Count == 0 && !string.IsNullOrEmpty(_searchQuery))
                                continue;

                            <div class="host-node indent @(hostMatches ? "search-highlight" : "")">
                                <span class="host-toggle" @onclick="() => ToggleHost(hostKey, matchingRecords.Any())">
                                    @(_expandedHosts.Contains(hostKey) ? "▼" : "▶") @hostGroup.Key
                                </span>
                                @if (_expandedHosts.Contains(hostKey))
                                {
                                    @foreach (var rec in hostGroup.OrderBy(r => r.RecordType.ToString()))
                                    {
                                        var recordMatches = MatchesSearch(rec.Data);
                                        if (!recordMatches && !string.IsNullOrEmpty(_searchQuery))
                                            continue;

                                        <div class="record-node indent2 @(recordMatches ? "search-highlight" : "")">
                                            <span class="badge-type @GetRecordTypeCssClass(rec.RecordType)">@rec.RecordType</span>
                                            <span class="record-data">@rec.Data</span>
                                            <button class="btn-copy" title="Copy record data" @onclick="() => CopyToClipboardAsync(rec.Data)">📋</button>
                                            <span class="text-muted">TTL:@rec.TimeToLive</span>
                                            @if (_isAdmin)
                                            {
                                                <button class="btn-delete" title="Delete record" disabled="@_isDeleting"
                                                        @onclick="() => ConfirmDelete(rec)">&#x2715;</button>
                                            }
                                        </div>
                                    }
                                    @if (_isAdmin)
                                    {
                                        <button class="btn-add indent" @onclick="() => ShowAddForm(zone.Name, hostGroup.Key)">
                                            + Add record under @hostGroup.Key
                                        </button>
                                    }
                                }
                            </div>
                        }
                        @if (_isAdmin)
                        {
                            <button class="btn-add indent" @onclick="() => ShowAddForm(zone.Name, null)">
                                + Add new record to @zone.Name
                            </button>
                        }
                    }
                }
            </div>
        }
    </div>
}

@* ── Add Record Modal ──────────────────────────────────────────────────────── *@
@if (_showAddForm)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h3>Add DNS Record</h3>
            <label>Zone
                <input @bind="_addForm.ZoneName" readonly />
            </label>
            <label>Host Name
                <input @bind="_addForm.HostName" placeholder="e.g. webserver or @@" 
                       class="@(_addFormErrors.ContainsKey("HostName") ? "validation-error" : "")" />
                @if (_addFormErrors.TryGetValue("HostName", out var hostErr))
                {
                    <div class="validation-message">@hostErr</div>
                }
            </label>
            <label>Type
                <select @bind="_addForm.RecordTypeStr">
                    <option>A</option>
                    <option>AAAA</option>
                    <option>CNAME</option>
                    <option>PTR</option>
                </select>
            </label>
            <label>Data
                <input @bind="_addForm.Data" placeholder="IP address or hostname" 
                       class="@(_addFormErrors.ContainsKey("Data") ? "validation-error" : "")" />
                @if (_addFormErrors.TryGetValue("Data", out var dataErr))
                {
                    <div class="validation-message">@dataErr</div>
                }
            </label>
            <label>TTL (seconds)
                <input type="number" @bind="_addForm.TimeToLive" min="60" max="2147483647"
                       class="@(_addFormErrors.ContainsKey("TimeToLive") ? "validation-error" : "")" />
                @if (_addFormErrors.TryGetValue("TimeToLive", out var ttlErr))
                {
                    <div class="validation-message">@ttlErr</div>
                }
            </label>
            @if (_modalError is not null)
            {
                <div class="alert-danger small">@_modalError</div>
            }
            <div class="modal-actions">
                <button class="btn-primary" @onclick="SubmitAddAsync" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="btn-spinner"></span>
                        <span>Adding…</span>
                    }
                    else
                    {
                        <span>Add Record</span>
                    }
                </button>
                <button @onclick="CloseAddForm" disabled="@_isSubmitting">Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Delete Confirm Modal ──────────────────────────────────────────────────── *@
@if (_deleteTarget is not null)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h3>Confirm Delete</h3>
            <p>Are you sure you want to delete this record?</p>
            <table class="confirm-table">
                <tr><th>Zone</th><td>@_deleteTarget.ZoneName</td></tr>
                <tr><th>Host</th><td>@_deleteTarget.HostName</td></tr>
                <tr><th>Type</th><td>@_deleteTarget.RecordType</td></tr>
                <tr><th>Data</th><td>@_deleteTarget.Data</td></tr>
            </table>
            @if (_modalError is not null)
            {
                <div class="alert-danger small">@_modalError</div>
            }
            <div class="modal-actions">
                <button class="btn-danger" @onclick="ExecuteDeleteAsync" disabled="@_isDeleting">
                    @if (_isDeleting)
                    {
                        <span class="btn-spinner"></span>
                        <span>Deleting…</span>
                    }
                    else
                    {
                        <span>Delete</span>
                    }
                </button>
                <button @onclick="() => { _deleteTarget = null; _modalError = null; }" disabled="@_isDeleting">Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Toast Notifications ──────────────────────────────────────────────────── *@
<div class="toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="toast toast-@toast.Type.ToString().ToLower()" role="alert">
            <span class="toast-message">@toast.Message</span>
            <button class="btn-close-toast" @onclick="() => RemoveToast(toast.Id)" aria-label="Close notification">✕</button>
        </div>
    }
</div>

@code {
    private IReadOnlyList<DnsZone> _zones = [];
    private bool _loading = true;
    private string? _error;
    private bool _isAdmin;

    private readonly HashSet<string> _expandedZones = new();
    private readonly HashSet<string> _expandedHosts = new();
    private readonly HashSet<string> _zoneLoading = new();
    private readonly Dictionary<string, IReadOnlyList<DnsRecord>> _zoneRecords = new();

    // Search state
    private string _searchQuery = string.Empty;
    private int _searchResults;
    private ElementReference _searchInput;

    // Toast state
    private readonly List<Toast> _toasts = new();
    private int _nextToastId;

    // Add form state
    private bool _showAddForm;
    private AddFormModel _addForm = new();
    
    private string? _modalError;
    private bool _isSubmitting;
    private readonly Dictionary<string, string> _addFormErrors = new();

    // Delete state
    private DnsRecord? _deleteTarget;
    private bool _isDeleting;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            _isAdmin = auth.User.IsInRole("DnsAdmins") || auth.User.IsInRole("Domain Admins");
        }

        try
        {
            _zones = await DnsService.ListZonesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load DNS zones");
            _error = $"Failed to load zones: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowAddForm(string zone, string? host)
    {
        _addForm = new AddFormModel
        {
            ZoneName = zone,
            HostName = host ?? string.Empty,
            RecordTypeStr = "A",
            TimeToLive = 3600
        };
        _modalError = null;
        _showAddForm = true;
    }

    private void CloseAddForm()
    {
        _showAddForm = false;
        _modalError = null;
    }

    private async Task SubmitAddAsync()
    {
        _modalError = null;
        _addFormErrors.Clear();

        // Validate hostname
        if (string.IsNullOrWhiteSpace(_addForm.HostName))
        {
            _addFormErrors["HostName"] = "Host name is required.";
        }
        else if (!IsValidHostname(_addForm.HostName))
        {
            _addFormErrors["HostName"] = "Invalid hostname. Use alphanumeric, hyphens, or @ for apex.";
        }

        // Validate data
        if (string.IsNullOrWhiteSpace(_addForm.Data))
        {
            _addFormErrors["Data"] = "Data field is required.";
        }
        else
        {
            var dataError = ValidateRecordData(_addForm.RecordTypeStr, _addForm.Data);
            if (!string.IsNullOrEmpty(dataError))
            {
                _addFormErrors["Data"] = dataError;
            }
        }

        // Validate TTL
        if (_addForm.TimeToLive < 60 || _addForm.TimeToLive > 2147483647)
        {
            _addFormErrors["TimeToLive"] = "TTL must be between 60 and 2147483647.";
        }

        if (_addFormErrors.Count > 0)
            return;

        if (!Enum.TryParse<DnsRecordType>(_addForm.RecordTypeStr, out var recordType))
        {
            _modalError = "Invalid record type.";
            return;
        }

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            await DnsService.AddRecordAsync(new AddRecordRequest
            {
                ZoneName = _addForm.ZoneName,
                HostName = _addForm.HostName,
                RecordType = recordType,
                Data = _addForm.Data,
                TimeToLive = _addForm.TimeToLive
            });

            // Refresh the zone record cache
            _zoneRecords.Remove(_addForm.ZoneName);
            _expandedZones.Add(_addForm.ZoneName);
            _zoneRecords[_addForm.ZoneName] = await DnsService.ListRecordsAsync(_addForm.ZoneName);
            ShowSuccessToast($"Record created: {_addForm.HostName} ({_addForm.RecordTypeStr})");

            _showAddForm = false;
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
                    ShowErrorToast($"Failed to create record: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ConfirmDelete(DnsRecord record)
    {
        _deleteTarget = record;
        _modalError = null;
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_deleteTarget is null) return;
        _modalError = null;
        _isDeleting = true;
        StateHasChanged();

        try
        {
            await DnsService.DeleteRecordAsync(new DeleteRecordRequest
            {
                ZoneName = _deleteTarget.ZoneName,
                HostName = _deleteTarget.HostName,
                RecordType = _deleteTarget.RecordType,
                Data = _deleteTarget.Data
            });

            // Refresh the zone record cache
            var zone = _deleteTarget.ZoneName;
            _zoneRecords.Remove(zone);
            _zoneRecords[zone] = await DnsService.ListRecordsAsync(zone);

            _deleteTarget = null;
                    ShowSuccessToast($"Record deleted: {_deleteTarget?.HostName} ({_deleteTarget?.RecordType})");
                    ShowErrorToast($"Failed to delete record: {ex.Message}");
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private sealed class Toast
    {
        public int Id { get; set; }
        public string Message { get; set; } = string.Empty;
        public ToastType Type { get; set; } = ToastType.Info;
    }

    private enum ToastType
    {
        Success,
        Error,
        Warning,
        Info
    }

    private sealed class AddFormModel
    {
        public string ZoneName { get; set; } = string.Empty;
        public string HostName { get; set; } = string.Empty;
        public string RecordTypeStr { get; set; } = "A";
        public string Data { get; set; } = string.Empty;
        public int TimeToLive { get; set; } = 3600;
    }

    // ── Helper Methods ────────────────────────────────────────────────────────

    private string GetRecordTypeCssClass(DnsRecordType type)
    {
        return type switch
        {
            DnsRecordType.A => "badge-type-a",
            DnsRecordType.AAAA => "badge-type-aaaa",
            DnsRecordType.CNAME => "badge-type-cname",
            DnsRecordType.PTR => "badge-type-ptr",
            _ => "badge-type-a"
        };
    }

    private bool IsValidHostname(string hostname)
    {
        // Allow "@" for apex, alphanumeric with hyphens and dots
        if (hostname == "@") return true;
        if (string.IsNullOrWhiteSpace(hostname)) return false;

        var pattern = @"^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)*@?[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?$";
        return System.Text.RegularExpressions.Regex.IsMatch(hostname, pattern);
    }

    private string? ValidateRecordData(string recordType, string data)
    {
        if (string.IsNullOrWhiteSpace(data)) return null;

        return recordType switch
        {
            "A" => ValidateIPv4(data) ? null : "Invalid IPv4 address.",
            "AAAA" => ValidateIPv6(data) ? null : "Invalid IPv6 address.",
            "CNAME" => IsValidHostname(data) ? null : "Invalid hostname for CNAME.",
            "PTR" => IsValidHostname(data) ? null : "Invalid hostname for PTR.",
            _ => null
        };
    }

    private bool ValidateIPv4(string ip)
    {
        var parts = ip.Split('.');
        if (parts.Length != 4) return false;
        return parts.All(p => int.TryParse(p, out var octet) && octet >= 0 && octet <= 255);
    }

    private bool ValidateIPv6(string ip)
    {
        // Simple IPv6 validation: contains colons, hex digits, max groups
        return System.Net.IPAddress.TryParse(ip, out var addr) && addr.AddressFamily == System.Net.Sockets.AddressFamily.InterNetworkV6;
    }

    private async Task CopyToClipboardAsync(string text)
    {
        try
        {
            // Use JS interop if available, otherwise just show a message
            // For now, we'll log success client-side in a real implementation
            await Task.Delay(100); // Simulate copy
            _modalError = "Copied to clipboard!";
            // Auto-clear after 2 seconds
            _ = Task.Delay(2000).ContinueWith(_ => { _modalError = null; StateHasChanged(); });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Copy to clipboard failed");
        }
    }

    // ── Search Methods ────────────────────────────────────────────────────────

    private bool MatchesSearch(string text)
    {
        if (string.IsNullOrEmpty(_searchQuery)) return true;
        return text.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase);
    }

    private void UpdateSearchResults()
    {
        if (string.IsNullOrEmpty(_searchQuery))
        {
            _searchResults = 0;
            return;
        }

        var zoneCount = _zones.Count(z => MatchesSearch(z.Name));
        var hostCount = 0;
        var recordCount = 0;

        foreach (var zone in _zones)
        {
            if (_zoneRecords.TryGetValue(zone.Name, out var records))
            {
                hostCount += records
                    .GroupBy(r => r.HostName)
                    .Count(g => MatchesSearch(g.Key));

                recordCount += records.Count(r => MatchesSearch(r.Data));
            }
        }

        _searchResults = zoneCount + hostCount + recordCount;
    }

    private async Task HandleSearchKeydownAsync(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Code == "KeyF")
        {
            e.PreventDefault();
            if (_searchInput.Context != null)
            {
                await _searchInput.FocusAsync();
            }
        }
    }

    private void HandleSearchKeydown(KeyboardEventArgs e)
    {
        // Prevent default browser search for Ctrl+F
        if (e.CtrlKey && e.Code == "KeyF")
        {
            e.PreventDefault();
        }
    }

    private async Task ClearSearchAsync()
    {
        _searchQuery = string.Empty;
        _searchResults = 0;
        // Auto-collapse all expanded items when search is cleared
        if (_searchInput.Context != null)
        {
            await _searchInput.FocusAsync();
        }
        StateHasChanged();
    }

    // Override ToggleZoneAsync to support search auto-expand
    private async Task ToggleZoneAsync(string zoneName, bool hasMatchingRecords = false)
    {
        // If searching and zone has matches, auto-expand
        if (!string.IsNullOrEmpty(_searchQuery) && hasMatchingRecords && !_expandedZones.Contains(zoneName))
        {
            _expandedZones.Add(zoneName);
            if (!_zoneRecords.ContainsKey(zoneName))
            {
                _zoneLoading.Add(zoneName);
                StateHasChanged();
                try
                {
                    _zoneRecords[zoneName] = await DnsService.ListRecordsAsync(zoneName);
                    UpdateSearchResults();
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, $"Failed to load records for zone {zoneName}");
                }
                finally
                {
                    _zoneLoading.Remove(zoneName);
                }
            }
            return;
        }

        // Normal toggle behavior
        if (!_expandedZones.Add(zoneName))
        {
            _expandedZones.Remove(zoneName);
            return;
        }

        if (_zoneRecords.ContainsKey(zoneName)) return;

        _zoneLoading.Add(zoneName);
        StateHasChanged();

        try
        {
            _zoneRecords[zoneName] = await DnsService.ListRecordsAsync(zoneName);
            UpdateSearchResults();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, $"Failed to load records for zone {zoneName}");
        }
        finally
        {
            _zoneLoading.Remove(zoneName);
        }
    }

    // Override ToggleHost to support search auto-expand
    private void ToggleHost(string hostKey, bool hasMatchingRecords = false)
    {
        // If searching and host has matches, auto-expand
        if (!string.IsNullOrEmpty(_searchQuery) && hasMatchingRecords && !_expandedHosts.Contains(hostKey))
        {
            _expandedHosts.Add(hostKey);
            UpdateSearchResults();
            return;
        }

        // Normal toggle
        if (!_expandedHosts.Add(hostKey))
        {
            _expandedHosts.Remove(hostKey);
        }
    }

    // ── Toast Methods ────────────────────────────────────────────────────────

    private void ShowToast(string message, ToastType type = ToastType.Info, int durationMs = 3000)
    {
        var toast = new Toast
        {
            Id = _nextToastId++,
            Message = message,
            Type = type
        };
        _toasts.Add(toast);
        StateHasChanged();

        // Auto-remove after duration
        _ = Task.Delay(durationMs).ContinueWith(_ =>
        {
            RemoveToast(toast.Id);
        });
    }

    private void ShowSuccessToast(string message, int durationMs = 3000)
        => ShowToast(message, ToastType.Success, durationMs);

    private void ShowErrorToast(string message, int durationMs = 4000)
        => ShowToast(message, ToastType.Error, durationMs);

    private void ShowWarningToast(string message, int durationMs = 3500)
        => ShowToast(message, ToastType.Warning, durationMs);

    private void ShowInfoToast(string message, int durationMs = 3000)
        => ShowToast(message, ToastType.Info, durationMs);

    private void RemoveToast(int id)
    {
        var toast = _toasts.FirstOrDefault(t => t.Id == id);
        if (toast is not null)
        {
            _toasts.Remove(toast);
            StateHasChanged();
        }
    }
}

